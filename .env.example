# Google OAuth Configuration
# Get these values from Google Cloud Console: https://console.cloud.google.com

# Your Google OAuth Client ID
GOOGLE_CLIENT_ID=YOUR_CLIENT_ID_HERE

# Your Google OAuth Client Secret
GOOGLE_CLIENT_SECRET=YOUR_CLIENT_SECRET_HERE

# Session secret for encryption
SESSION_SECRET=your-super-secret-session-key-change-this

# Server port
# For local: 3000
# For Google Cloud Run: 8080
PORT=3000

# Environment mode
# development - for localhost testing
# production - for Google Cloud deployment
NODE_ENV=development

# Callback URL - must match Google Cloud Console settings
# For local: http://localhost:3000/auth/google/callback
# For Google Cloud Run: https://your-app-name.run.app/auth/google/callback
CALLBACK_URL=http://localhost:3000/auth/google/callback

# Google Cloud Settings (only for production)
# PROJECT_ID=your-google-cloud-project-id
# CLOUD_RUN_REGION=us-central1
