<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>StockView - Google OAuth Demo</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <div class="navbar">
    <div class="nav-container">
      <h1 class="logo">📈 StockView</h1>
      <% if (user) { %>
        <div class="nav-user">
          <img src="<%= user.photo %>" alt="Profile" class="profile-pic">
          <span class="user-name"><%= user.displayName %></span>
          <a href="/logout" class="btn-logout">Logout</a>
        </div>
      <% } %>
    </div>
  </div>

  <div class="container">
    <% if (!user) { %>
      <div class="login-section">
        <div class="welcome-box">
          <h2>Welcome to StockView</h2>
          <p>Real-time stock market insights powered by Google OAuth</p>
          <a href="/auth/google" class="btn-google">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
              <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Sign in with Google
          </a>
        </div>
        <div class="info-box">
          <h3>🔐 Why Google OAuth?</h3>
          <ul>
            <li>Secure authentication</li>
            <li>No need to remember passwords</li>
            <li>Access your Google account safely</li>
            <li>Instant account creation</li>
          </ul>
        </div>
      </div>
    <% } else { %>
      <div class="dashboard-redirect">
        <p>Redirecting to dashboard...</p>
      </div>
      <script>
        window.location.href = '/dashboard';
      </script>
    <% } %>
  </div>

  <footer>
    <p>&copy; 2026 StockView - OAuth Lab Assignment Demo</p>
  </footer>
</body>
</html>
